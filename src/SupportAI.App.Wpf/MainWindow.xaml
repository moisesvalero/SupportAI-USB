<Window x:Class="SupportAI.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SupportAI.App.Wpf.ViewModels"
        xmlns:conv="clr-namespace:SupportAI.App.Wpf.Converters"
        mc:Ignorable="d"
        Title="SupportAI USB" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#f5f6fa"
        FontFamily="Segoe UI, sans-serif"
        TextElement.Foreground="#2c3e50"
        d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}">
    <Window.Resources>
        <conv:GravedadToColorConverter x:Key="GravedadColor"/>
        <conv:BoolToIconConverter x:Key="BoolIcon"/>
        <conv:BoolToCheckColorConverter x:Key="CheckColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:ScoreToColorConverter x:Key="ScoreColor"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Opacity="0.08" BlurRadius="12" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2c3e50" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SupportAI USB" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Asistente portátil de diagnóstico para Windows" FontSize="12" Foreground="#bdc3c7"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Escanear" Command="{Binding ScanCommand}"
                        FontSize="14" FontWeight="SemiBold"
                        Background="#27ae60" Foreground="White"
                        BorderThickness="0" Padding="24,8" Cursor="Hand"
                        Width="140" Height="36"/>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                <StackPanel>
                    <!-- Score -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="80" Height="80" CornerRadius="40" Background="White"
                                    BorderBrush="{Binding Puntuacion, Converter={StaticResource ScoreColor}}"
                                    BorderThickness="4">
                                <TextBlock Text="{Binding Puntuacion}" FontSize="32" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{Binding Puntuacion, Converter={StaticResource ScoreColor}}"/>
                            </Border>
                            <Border Width="1"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Salud general" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Tras escanear verás el resultado" FontSize="11" Foreground="#7f8c8d"
                                           TextWrapping="Wrap" MaxWidth="140"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- System Info -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Sistema" FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,6"/>
                            <Separator Background="#ecf0f1" Height="1" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Sistema, TargetNullValue='—'}" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CpuInfo, TargetNullValue='—'}" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding RamInfo, StringFormat='RAM: {0}', TargetNullValue='—'}" FontSize="12" Foreground="#555"/>
                                <TextBlock Grid.Column="2" Text="{Binding RamUso, StringFormat='Uso: {0}', TargetNullValue='—'}" FontSize="12" Foreground="#555"/>
                            </Grid>
                            <TextBlock Text="{Binding Uptime, StringFormat='Activo: {0}', TargetNullValue='—'}" FontSize="12" Foreground="#555"/>
                            <TextBlock Text="{Binding RedInfo, StringFormat='Red: {0}'}" FontSize="12" Foreground="#555" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Module Checks -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Componentes" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Separator Background="#ecf0f1" Height="1" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Modulos}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Ok, Converter={StaticResource BoolIcon}}"
                                                       Foreground="{Binding Ok, Converter={StaticResource CheckColor}}"
                                                       FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Nombre}" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- IA config -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Análisis IA" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Separator Background="#ecf0f1" Height="1" Margin="0,0,0,6"/>
                            <CheckBox IsChecked="{Binding IaConsent}" Margin="0,0,0,8">
                                <TextBlock Text="He informado al cliente y autoriza el envío de datos técnicos al proveedor IA" 
                                          FontSize="11" Foreground="#555" TextWrapping="Wrap" MaxWidth="220"/>
                            </CheckBox>
                            <Button Content="Analizar con IA" Command="{Binding AnalyzeWithIaCommand}"
                                    FontSize="12" Padding="12,6" Background="#8e44ad" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    IsEnabled="{Binding PuedeAnalizarConIa}"
                                    HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IaProvider, StringFormat='Proveedor: {0}', TargetNullValue='Reglas offline'}" 
                                       FontSize="10" Foreground="#95a5a6" Margin="0,4,0,0"/>
                            <Separator Background="#ecf0f1" Height="1" Margin="0,8,0,6"/>
                            <TextBlock Text="Modelo local (GGUF)" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ModelStatus}" FontSize="10" Foreground="#7f8c8d" TextWrapping="Wrap"/>
                            <Button Content="Descargar llama.cpp + modelo" Command="{Binding DownloadModelCommand}"
                                    FontSize="10" Padding="8,4" Background="#7f8c8d" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Problems -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Problemas detectados" FontSize="14" FontWeight="SemiBold"
                                       Visibility="{Binding HayProblemas, Converter={StaticResource BoolVis}}"/>
                            <ItemsControl ItemsSource="{Binding Problemas}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#fafafa" CornerRadius="6" Padding="12,8" Margin="0,4">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="●" FontSize="14"
                                                               Foreground="{Binding Gravedad, Converter={StaticResource GravedadColor}}"
                                                               Margin="0,0,6,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Titulo}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Gravedad}" FontSize="11"
                                                               Foreground="#7f8c8d"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Detalle}" FontSize="11" Foreground="#555"
                                                           TextWrapping="Wrap" Margin="16,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No se detectaron problemas" FontSize="13" Foreground="#27ae60" Margin="0,8,0,0"
                                       Visibility="{Binding HayProblemas, Converter={StaticResource BoolVis}, ConverterParameter=invert}"/>
                        </StackPanel>
                    </Border>

                    <!-- Repairs -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Reparaciones" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Separator Background="#ecf0f1" Height="1" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Repairs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Titulo}"
                                                Command="{Binding DataContext.RepairCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                FontSize="11" Padding="8,6" Margin="2"
                                                Background="#ecf0f1" Foreground="#2c3e50"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="{Binding Descripcion}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- IA Results -->
                    <Border Style="{StaticResource Card}" Visibility="{Binding TieneIaResultado, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Análisis IA" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Separator Background="#ecf0f1" Height="1" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding IaExplicacion}" FontSize="12" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding IaProvider, StringFormat='— {0}'}" FontSize="10" Foreground="#95a5a6" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Exportar PDF" Command="{Binding ExportPdfCommand}"
                                    FontSize="13" Padding="20,10" Background="#3498db" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                            <Button Content="Ver comandos CLI"
                                    FontSize="13" Padding="20,10" Background="#95a5a6" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="VerComandos_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#ecf0f1" Padding="16,6">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#555"/>
        </Border>
    </Grid>
</Window>
